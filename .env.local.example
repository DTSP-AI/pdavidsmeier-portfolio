OPENAI_API_KEY=sk-your-key-here

# Vercel Blob (used by /api/access-request to store signed NCNDAs).
# Auto-injected by `vercel env pull` once a Blob store is connected.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# HMAC-SHA256 secret shared with the gated apps (deal-whisper-live,
# real-time-med-agent). Used to mint and verify access tokens minted
# after a successful NCNDA signature. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# The same value MUST be set on every project that mints or verifies.
NCNDA_GATE_SECRET=replace-with-32-bytes-base64url
